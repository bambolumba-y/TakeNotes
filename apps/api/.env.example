# ─── Supabase ─────────────────────────────────────────────────────────────────
# Supabase project URL (e.g., https://your-project.supabase.co)
SUPABASE_URL=

# Public anon key — safe to use in API for auth verification calls
SUPABASE_ANON_KEY=

# Service role key — grants full database access, bypasses RLS.
# NEVER expose this to the mobile client or commit it to source control.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Redis ────────────────────────────────────────────────────────────────────
# Redis connection string for BullMQ job queue
# Example: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Resend API key for sending reminder emails (SECRET — never expose to client)
RESEND_API_KEY=

# Sender email address (must be verified in Resend)
RESEND_FROM_EMAIL=reminders@takenotes.app

# ─── Telegram ─────────────────────────────────────────────────────────────────
# Telegram bot token from BotFather (SECRET — never expose to client)
TELEGRAM_BOT_TOKEN=

# Random secret for validating incoming Telegram webhook calls (SECRET)
# Generate with: openssl rand -base64 32
TELEGRAM_WEBHOOK_SECRET=

# ─── Expo Push Notifications ──────────────────────────────────────────────────
# Expo access token for sending push notifications via Expo Push Service
# Obtain from: https://expo.dev → Account → Access Tokens
EXPO_ACCESS_TOKEN=

# ─── App Deep Links ───────────────────────────────────────────────────────────
# Base URL for app deep links used in reminder email CTAs
# Production: takenotes://
# Local development: exp://192.168.1.100:8081
APP_DEEP_LINK_BASE=takenotes://

# ─── Sentry ───────────────────────────────────────────────────────────────────
# Sentry DSN for API error tracking (SECRET — do not share publicly)
# Obtain from: https://sentry.io → Project → Settings → Client Keys (DSN)
SENTRY_DSN=

# ─── Server ───────────────────────────────────────────────────────────────────
# Application environment: development | production | test
NODE_ENV=development

# API server port (default: 3000)
PORT=3000

# Pino log level: trace | debug | info | warn | error | fatal (default: info)
LOG_LEVEL=info
