{
  "name": "@takenotes/api",
  "version": "0.0.1",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "start:prod": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@takenotes/shared": "workspace:*",
    "dotenv": "^16.4.0",
    "fastify": "^4.26.0",
    "@fastify/cors": "^9.0.0",
    "zod": "^3.22.0",
    "ioredis": "^5.3.0",
    "@sentry/node": "^8.0.0",
    "@supabase/supabase-js": "^2.43.0",
    "bullmq": "^5.0.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "ts-node-dev": "^2.0.0",
    "vitest": "^1.4.0",
    "@vitest/coverage-v8": "^1.4.0"
  }
