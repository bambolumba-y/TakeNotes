# ─── API ──────────────────────────────────────────────────────────────────────
# Base URL for the TakeNotes API server
# Local development: http://localhost:3000
# Production: https://api.yourdomain.com
EXPO_PUBLIC_API_URL=http://localhost:3000

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Supabase project URL (e.g., https://your-project.supabase.co)
EXPO_PUBLIC_SUPABASE_URL=

# Public anon key ONLY — never use the service role key here.
# The service role key must only exist in apps/api/.env.
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ─── Telegram ─────────────────────────────────────────────────────────────────
# The public username of your Telegram bot (without the @ prefix)
# Example: takenotes_bot
EXPO_PUBLIC_TELEGRAM_BOT_USERNAME=
